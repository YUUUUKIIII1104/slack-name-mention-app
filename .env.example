# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
# Socket Mode を使う場合のみ必要
# SLACK_APP_TOKEN=xapp-your-app-token

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key

# Google Cloud Vision
GOOGLE_CLOUD_KEY_FILE=credentials/google-cloud-key.json

# Server
PORT=3000
NODE_ENV=development

# Tests (optional)
TEST_CHANNEL_ID=C0000000000
TEST_FILE_ID=F0000000000
TEST_IMAGE_URL=https://cloud.google.com/vision/docs/images/sign_text.png
TEST_SLACK_FILE_URL=https://files.slack.com/files-pri/TEAM_ID-FILE_ID/image.jpg
